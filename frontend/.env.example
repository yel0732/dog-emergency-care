# Frontend environment variables
#
# 1. Copy this file and rename the copy to ".env".
# 2. Put your own Kakao JavaScript key in VITE_KAKAO_JS_KEY.
# 3. Restart the frontend dev server after editing ".env".
#
# Important:
# - Do not put real keys in this .env.example file.
# - Backend keys such as Kakao REST, Google Places, OpenAI, KMA, and AirKorea
#   belong in ../.env, not in the frontend/browser environment.

VITE_KAKAO_JS_KEY=put-your-kakao-javascript-key-here
